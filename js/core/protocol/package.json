{
  "name": "@quadra-a/protocol",
  "version": "0.0.1",
  "description": "Protocol implementation for quadra-a",
  "type": "module",
  "keywords": [
    "protocol",
    "agent",
    "communication",
    "cryptography",
    "ed25519",
    "quadra-a"
  ],
  "homepage": "https://github.com/quadra-a/a4#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/quadra-a/a4.git",
    "directory": "js/core/protocol"
  },
  "bugs": {
    "url": "https://github.com/quadra-a/a4/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/ciphers": "^0.5.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.8.0",
    "ajv": "^8.17.1",
    "cbor-x": "^1.6.0",
    "level": "^8.0.0",
    "multiformats": "^13.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/level": "^6.0.0",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.10",
    "memory-level": "^3.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "GPL-3.0"
